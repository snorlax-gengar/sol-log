VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_DEFAULT_CHILD_ID=your_children_table_uuid

# 로그인 프로필 카드에 매핑되는 Supabase Auth 계정 이메일 (미설정 시 기본값 사용)
VITE_ACCOUNT_MOM_EMAIL=mom@sol-log.family
VITE_ACCOUNT_DAD_EMAIL=dad@sol-log.family
VITE_ACCOUNT_CHILD_EMAIL=child@sol-log.family

# 서버 푸시 알람용 VAPID '공개'키 (web-push generate-vapid-keys로 생성한 publicKey)
# 개인키는 클라이언트에 절대 넣지 말 것 (Supabase secrets로만 관리)
VITE_VAPID_PUBLIC_KEY=
VITE_VAPID_PRIVATE_KEY=
