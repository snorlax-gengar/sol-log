VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# 아이 ID: 로그인 후 children 테이블에서 자동 해석됩니다.
# 아래 값은 DB 조회 실패 시 폴백일 뿐이라 비워둬도 됩니다(선택).
VITE_DEFAULT_CHILD_ID=

# 로그인 프로필 카드에 매핑되는 Supabase Auth 계정 이메일 (미설정 시 기본값 사용)
VITE_ACCOUNT_MOM_EMAIL=
VITE_ACCOUNT_DAD_EMAIL=
VITE_ACCOUNT_CHILD_EMAIL=

# 서버 푸시 알람용 VAPID '공개'키 (web-push generate-vapid-keys로 생성한 publicKey)
# 개인키는 클라이언트에 절대 넣지 말 것 (Supabase secrets로만 관리)
VITE_VAPID_PUBLIC_KEY=
VITE_VAPID_PRIVATE_KEY=
